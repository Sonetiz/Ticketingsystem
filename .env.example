# Database
DATABASE_URL=postgresql://ticketsystem:ticketsystem@localhost:5432/ticketsystem?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Backend
NODE_ENV=development
PORT=3001
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
CSRF_SECRET=change-me-csrf-secret
JWT_SECRET=change-me-jwt-secret
MAGIC_LINK_SECRET=change-me-magic-link-secret
ATTACHMENT_SIGNING_SECRET=change-me-attachment-secret
UPLOAD_DIR=./uploads

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
FRONTEND_URL=http://localhost:3000

# Email (MailHog for local dev)
EMAIL_CONNECTOR=mock
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=support@ticketsystem.local
IMAP_HOST=localhost
IMAP_PORT=1143
IMAP_USER=
IMAP_PASS=

# Microsoft Teams
TEAMS_CONNECTOR=mock

# Worker
WORKER_ENABLED=true
